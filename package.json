{
  "name": "@xsqm/pi-qqbot",
  "version": "0.4.7",
  "description": "A Pi extension that connects the official QQ Bot API to a local Pi coding agent.",
  "license": "Apache-2.0",
  "type": "module",
  "author": "XiaoSQM",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "qqbot",
    "qq-bot",
    "coding-agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XiaoSQM/pi-coding-agent-qqbot.git"
  },
  "bugs": {
    "url": "https://github.com/XiaoSQM/pi-coding-agent-qqbot/issues"
  },
  "homepage": "https://github.com/XiaoSQM/pi-coding-agent-qqbot#readme",
  "files": [
    "index.ts",
    "access-requests.ts",
    "attachment-downloader.ts",
    "attachment-extractors.ts",
    "attachment-pipeline.ts",
    "command-controller.ts",
    "command-parser.ts",
    "config.ts",
    "conversation-registry.ts",
    "host-registry.ts",
    "model-pages.ts",
    "outbound-media.ts",
    "qq-api.ts",
    "qq-auth.ts",
    "qq-gateway.ts",
    "qq-keyboard.ts",
    "qq-session.ts",
    "queue.ts",
    "reply-formatter.ts",
    "router.ts",
    "stt.ts",
    "terminal-view.ts",
    "types.ts",
    "user-facing.ts",
    "pi-qqbot.json.example",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx test/run-all.ts",
    "test:focused": "node --import tsx test/run-all.ts",
    "verify": "npm run typecheck && npm test",
    "prepack": "npm run verify",
    "prepublishOnly": "npm run verify",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "unpdf": "1.6.2",
    "ws": "^8.21.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.7",
    "@earendil-works/pi-tui": "^0.80.7",
    "@types/node": "^22.20.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.1",
    "typebox": "^1.1.38",
    "typescript": "^5.9.3"
  }
}
